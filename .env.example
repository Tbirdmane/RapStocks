# ── Supabase ────────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and paste your real values from the
# Supabase dashboard (Project Settings → API). NEVER commit .env.local.

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SECRET — server-only. This bypasses Row Level Security and runs all trades
# and settlements. Never expose this to the browser, never commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── App ──────────────────────────────────────────────────────────────────────
# Comma-separated list of profile handles allowed into /admin.
# Example: ADMIN_HANDLES=tighe,founder
ADMIN_HANDLES=

# Base URL of the deployed app (used by the share-card image route).
# Local dev: http://localhost:3000 . Production: your Vercel URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
